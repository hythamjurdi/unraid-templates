<?xml version="1.0"?>
<Container version="2">
    <Name>CHD-Converter</Name>
    <Repository>hythamjurdi/chd-converter:latest</Repository>
    <Registry>https://hub.docker.com/r/hythamjurdi/chd-converter</Registry>
    <Network>bridge</Network>
    <MyIP/>
    <Shell>bash</Shell>
    <Privileged>false</Privileged>
    <Support>https://github.com/hythamjurdi/CHD-Converter/issues</Support>
    <Project>https://github.com/hythamjurdi/CHD-Converter</Project>
    <Overview>
        Bulk ISO to CHD converter with a web UI. Supports .7z, .zip, .rar, .tar.gz archives,
        auto-detects CD vs HD images, handles multi-disc games, and provides a real-time
        conversion queue with live logs. Built with chdman (MAME).
    </Overview>
    <Category>MediaApp:Other Tools:</Category>
    <WebUI>http://[IP]:[PORT:9292]/</WebUI>
    <TemplateURL>https://raw.githubusercontent.com/hythamjurdi/CHD-Converter/main/unraid/CHD-Converter.xml</TemplateURL>
    <Icon>https://raw.githubusercontent.com/hythamjurdi/CHD-Converter/main/icon.png</Icon>
    <ExtraParams/>
    <PostArgs/>
    <CPUset/>
    <DateInstalled/>
    <DonateText/>
    <DonateLink/>
    <Description>
        Bulk ISO to CHD converter with Web UI. Features:
        - Converts ISO, IMG, BIN/CUE, MDF, NRG to CHD format
        - Extracts and converts from 7z, zip, rar, tar.gz archives
        - Auto-detects CD vs HD image type (or manual override)
        - Handles multi-disc games with proper CUE sheet support
        - Real-time web UI with live logs and progress
        - Auto-scan source folder with configurable interval
        - Delete ISO / archive after conversion options
        - Ask / Skip / Overwrite conflict resolution with apply-to-all
    </Description>
    <Networking>
        <Mode>bridge</Mode>
        <Publish>
            <Port>
                <HostPort>9292</HostPort>
                <ContainerPort>9292</ContainerPort>
                <Protocol>tcp</Protocol>
            </Port>
        </Publish>
    </Networking>
    <Data>
        <Volume>
            <HostDir>/mnt/user/isos</HostDir>
            <ContainerDir>/source</ContainerDir>
            <Mode>rw</Mode>
        </Volume>
        <Volume>
            <HostDir>/mnt/user/chd</HostDir>
            <ContainerDir>/destination</ContainerDir>
            <Mode>rw</Mode>
        </Volume>
        <Volume>
            <HostDir>/mnt/user/appdata/chd-converter</HostDir>
            <ContainerDir>/config</ContainerDir>
            <Mode>rw</Mode>
        </Volume>
    </Data>
    <Environment/>
    <Labels/>
    <Config Name="Web UI Port" Target="9292" Default="9292" Mode="tcp" Description="Port for the web interface" Type="Port" Display="always" Required="true" Mask="false">9292</Config>
    <Config Name="Source Folder" Target="/source" Default="/mnt/user/isos" Mode="rw" Description="Folder containing your ISO/archive files to convert" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/isos</Config>
    <Config Name="Destination Folder" Target="/destination" Default="/mnt/user/chd" Mode="rw" Description="Folder where converted CHD files will be saved" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/chd</Config>
    <Config Name="Config Folder" Target="/config" Default="/mnt/user/appdata/chd-converter" Mode="rw" Description="Stores settings between restarts" Type="Path" Display="advanced" Required="true" Mask="false">/mnt/user/appdata/chd-converter</Config>
</Container>
